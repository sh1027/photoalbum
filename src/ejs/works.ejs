<% var dataList = jsonDataList; %><!doctype html>
<html>
  <%- include('partial/_head'); %>
  <body>
    <%- include('partial/_nav', {current: 'works'}); %>
    <main>
      <div class="container">
        <div class="row">
          <% for (var i = 0; i < dataList.length; i++) { %>
          <a href="/works/<%= dataList[i].id %>.html" class="card">
            <div class="card-block img-guard"><span class="guard-nopic"></span>
              <img class="card-img" src="/img/works/<%= dataList[i].id %>/1.jpg" alt="<%= dataList[i].name %>"
              oncontextmenu="return false;" onselectstart="return false;" onmousedown="return false;">
            </div>
          </a>
          <% } %>
        </div>
      </div>
    </main>
    <%- include('partial/_footer'); %>
  </body>
</html>
