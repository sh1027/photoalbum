<% var data = album; %>
<% var imgNum = data.imgNum; %>
<% var title = data.name %>
<% var subTitle %>
<% data.tag == 'portraits' ? subTitle = data.date : subTitle = data.work; %>
<!doctype html>
<html>
  <%- include('partial/_head', {
    pageId: data.id
  }); %>
  <body>
    <div>
      <%- include('partial/_nav', {
        current: page.id
      }); %>
      <main>
        <div class="container-fluid album">
          <div class="row page">
            <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3 border-bottom border-dark">
              <div class="album-title">
                <h1><%- title %></h1>
                <p><%- subTitle %></p>
              </div>
              <div class="scroll">
                <a ref="#"><span></span>Scroll</a>
              </div>
            </div>
          </div>
          <% for (var i = 1; i <= imgNum; i++) { %>
          <div class="row page">
            <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3 border-bottom border-dark">
              <div class="img-guard page-photo"><span class="guard-nopic"></span>
                <img src="<%- site.rootPath %>/img/albums/<%- data.id %>/<%- i %>.jpg" alt="<%- data.name + i %>"
                oncontextmenu="return false;" onselectstart="return false;" onmousedown="return false;">
              </div>
            </div>
          </div>
          <% } %>
          <div class="row page">
            <div class="col-12 col-md-6 offset-md-3">
              <p class="col-12"><%- subTitle %></p>
              <p class="col-12">Model: <%- title %></p>
              <% if(data.tag == 'works') { %>
              <p class="col-12">
                Link: <a href="<%- data.link %>"><%- data.link %></a>
              </p>
              <% } %>
            </div>
            <div class="col-12 position-relative bg-light">
              <h3 class="text-center back">Back to albums</h3>
              <a href="<%- site.rootPath %><%- pages[1].relativePath %>" class="stretched-link"></a>
            </div>
            <div class="col-12">
              <%- include('partial/_footer_content'); %>
            </div>
          </div>
        </div>
      </main>
      <%- include('partial/_footer_js'); %>
    </div>
  </body>
</html>
