<% var data = album; %>
<% var imgNum = data.imgNum; %>
<% var title = data.name %>
<% var subTitle %>
<% data.tag == 'portraits' ? subTitle = data.date : subTitle = data.work; %>
<!doctype html>
<html>
  <%- include('partial/_head', {
    pageId: data.id
  }); %>
  <body>
    <div class="album">
      <%- include('partial/_nav', {
        current: page.id
      }); %>
      <main>
        <div class="container-fluid">
          <div class="row page" style="background-image: url(<%- site.rootPath %>/img/albums/<%- data.id %>/1.jpg);">
            <div class="col-12 border-bottom border-light" style="background: rgba(255,255,255,0.5);">
              <div class="album-title">
                <h1><%- title %></h1>
                <p><%- subTitle %></p>
              </div>
              <div class="scroll">
                <a ref="#"><span></span>Scroll</a>
              </div>
            </div>
          </div>
          <% for (var i = 1; i <= imgNum; i++) { %>
          <div class="row page">
            <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3 border-bottom border-light">
              <div class="img-guard page-photo"><span class="guard-nopic"></span>
                <img src="<%- site.rootPath %>/img/albums/<%- data.id %>/<%- i %>.jpg" alt="<%- data.name + i %>"
                oncontextmenu="return false;" onselectstart="return false;" onmousedown="return false;">
              </div>
              <p class="page-num"><%- ( '00' + i ).slice( -2 ); %></p>
            </div>
          </div>
          <% } %>
          <div class="row page">
            <div class="col-12 col-md-6 offset-md-3 align-self-end">
              <p><%- subTitle %></p>
              <p>Model: <%- title %></p>
              <% if(data.tag == 'works') { %>
              <p>
                Link: <a href="<%- data.link %>"><%- data.link %></a>
              </p>
              <% } %>
            </div>
            <div class="col-12 col-md-6 offset-md-3 align-self-end py-5 px-0">
              <div class="position-relative bg-light mb-5">
                <h3 class="text-center back my-0 pt-1">Back to albums</h3>
                <a href="<%- site.rootPath %><%- pages[1].relativePath %>" class="stretched-link"></a>
              </div>
              <%- include('partial/_footer_content'); %>
            </div>
          </div>
        </div>
      </main>
      <%- include('partial/_footer_js'); %>
    </div>
  </body>
</html>
