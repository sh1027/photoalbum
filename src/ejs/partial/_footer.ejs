<!-- footer -->
<footer class="footer">
  <div class="container-fluid">
    <div class="row m-2">
      <div class="col-6 px-3">
        <a class="fa-pull-right" href="<%- site.instagramAccount %>"><i class="fab fa-instagram" style="font-size: 2rem; color:rgba(0,0,0,0.8)"></i></a>
      </div>
      <div class="col-6 px-3">
        <a class="fa-pull-left" href="<%- site.twitterAccount %>"><i class="fab fa-twitter" style="font-size: 2rem; color:rgba(0,0,0,0.8)"></i></a>
      </div>
    </div>
    <p class="copyright text-center m-2"><small>&copy; <%- site.copyright %></small></p>
  </div>
</footer>
