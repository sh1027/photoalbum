<% site = siteMeta; %>
<% page = pageMeta; %>
<head>
  <!-- Required meta tags -->
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <!-- Bootstrap CSS -->
  <link rel="stylesheet" type="text/css" href="<%- site.rootPath %>/css/custom.css">

  <!-- Original CSS -->
  <link rel="stylesheet" type="text/css" href="<%- site.rootPath %>/css/styles.css">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css?family=Montserrat:300,400|Sacramento&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link href="https://use.fontawesome.com/releases/v5.6.1/css/all.css" rel="stylesheet">

  <!-- Title and Description -->
  <title><%- site.name %><%- (page.name == 'index') ? '' : (' | '  + page.name); %></title>
  <meta name="description" content="<%- (page.name == 'index') ? '' : (page.name + ' | '); %><%- site.description %>"/>

  <!-- OGP Tag -->
  <meta name="twitter:card" content="<%- site.twitterCard %>" />
  <meta name="twitter:site" content="<%- site.twitterSite %>" />
  <meta property="og:url" content="<%- site.rootUrl %><%- page.relativePath %><%- (page.temp == true) ? (pageId + '.html') : ''; %>" />
  <meta property="og:title" content="<%- site.name %><%- (page.name == 'index') ? '' : (' | '  + page.name); %>" />
  <meta property="og:description" content="<%- (page.name == 'index') ? '' : (page.name + ' | '); %><%- site.description %>" />
  <meta property="og:image" content="<%- site.rootUrl %><%- page.img %><%- (page.temp == true) ? (pageId + '/1.jpg') : ''; %>" />

  <!-- Icon -->
  <!-- <link rel="icon" href="<%- site.rootPath %><%- site.icoIcon %>">
  <link rel="apple-touch-icon" sizes="180x180" href="<%- site.rootPath %><%- site.pngIcon %>"> -->
</head>
